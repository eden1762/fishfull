{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/ar", "destination": "/ar.html" },
    { "source": "/catch", "destination": "/pages/catch.html" },
    { "source": "/about", "destination": "/pages/about.html" },
    { "source": "/map", "destination": "/pages/map.html" },
    { "source": "/recipes", "destination": "/pages/recipes.html" },
    { "source": "/feedback", "destination": "/pages/feedback.html" },
    { "source": "/sustainability", "destination": "/pages/sustainability.html" },
    { "source": "/pages/ar", "destination": "/ar.html" },
    { "source": "/pages/catch", "destination": "/pages/catch.html" },
    { "source": "/pages/about", "destination": "/pages/about.html" },
    { "source": "/pages/map", "destination": "/pages/map.html" },
    { "source": "/pages/recipes", "destination": "/pages/recipes.html" },
    { "source": "/pages/feedback", "destination": "/pages/feedback.html" },
    { "source": "/pages/sustainability", "destination": "/pages/sustainability.html" }
  ]
}
